# AgentKit — Variables de entorno
# Copia este archivo como .env y completa tus valores reales
# NUNCA subir .env a GitHub

# ════════════════════════════════════════════════════════════
# ANTHROPIC API
# ════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...

# ════════════════════════════════════════════════════════════
# WHATSAPP — PROVEEDOR
# ════════════════════════════════════════════════════════════
WHATSAPP_PROVIDER=twilio    # Options: meta, twilio

# --- Si WHATSAPP_PROVIDER=meta ---
# META_ACCESS_TOKEN=...
# META_PHONE_NUMBER_ID=...
# META_VERIFY_TOKEN=agentkit-verify

# --- Si WHATSAPP_PROVIDER=twilio ---
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=whatsapp:+...

# ════════════════════════════════════════════════════════════
# GOOGLE CLOUD — SHEETS, CALENDAR, GMAIL
# ════════════════════════════════════════════════════════════
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
GOOGLE_SHEET_ID=...                    # ID de tu Google Sheet
GOOGLE_CALENDAR_ID=primary             # ID del calendario

# ════════════════════════════════════════════════════════════
# OPENAI — WHISPER (TRANSCRIPCIÓN DE AUDIOS)
# ════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-...

# ════════════════════════════════════════════════════════════
# SERVIDOR
# ════════════════════════════════════════════════════════════
PORT=8000
ENVIRONMENT=development    # Options: development, production

# ════════════════════════════════════════════════════════════
# BASE DE DATOS
# ════════════════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Para producción en Railway con PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
